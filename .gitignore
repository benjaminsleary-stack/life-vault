# Obsidian local state + workspace — do NOT sync via git (Obsidian Sync owns it).
.obsidian/
.trash/
# obsidian-git's conflict marker file (we use our own conflict/ branches).
conflict-files-obsidian-git.md
# Legacy app + stale vault config — never commit (delete once fresh start verified).
.superceeded/
.vault/
# Installed plugin clone — not vault content.
.claude/obsidian-skills/
# Transient script working dirs (mail bodies/attachments are never committed).
scripts/.venv/
scripts/_work/
# Secrets. A private .ics feed URL is a credential — anyone holding it can read
# the calendar — and so are the mail and push keys. Only .env.example is tracked.
.env
.env.*
!.env.example
.dev.vars
# Wrangler (Cloudflare) local cache for the dashboard worker + PWA.
.wrangler/
node_modules/
*.pyc
__pycache__/
.DS_Store
