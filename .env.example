# Secrets for the scripts. On the DESKTOP bridge, source this (or export these) so
# notify.sh can alert. In the CLOUD routine environment, set these as Environment
# Variables in the environment config — NEVER in a routine prompt (spec §6).
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx      # Google app password (needs 2FA)
ICS_URL=https://calendar.google.com/calendar/ical/.../basic.ics   # private read-only

# Calendars the DASHBOARD subscribes to (Agenda card). Private .ics URLs are
# credentials — anyone holding one can read the calendar. Locally these live in
# .env (gitignored); deployed they are Worker secrets:
#   cd worker && npx wrangler secret put CAL_WORK
CAL_WORK=https://outlook.office365.com/owa/calendar/<id>/<token>/calendar.ics
CAL_PERSONAL=https://calendar.google.com/calendar/ical/.../basic.ics
NTFY_TOPIC=life-vault-<random-hard-to-guess>
# NTFY_SERVER=https://ntfy.sh                # override for self-hosted
# NTFY_TOKEN=                                # only if the topic is access-protected
HEALTHCHECK_URL=https://hc-ping.com/<uuid>   # healthchecks.io ping (silence = alarm)
# MAIL_SINCE_HOURS=24
